<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:property name="distance_to_roller1_center" value="0.08688"/> 
    <xacro:property name="distance_to_roller2_center" value="0.09485"/> 

    <xacro:macro name="insert_roller1" params="parent theta suffix wheel"> <!--大从动轮-->
        <joint name="wheel${wheel}_roller1${suffix}_joint" type="continuous">
            <origin xyz="0.0 ${-distance_to_roller1_center*cos(1.8521+theta)} ${-distance_to_roller1_center*sin(1.8521+theta)}" rpy="${theta+1.8792} 0.0 0.0"/>
            <parent link="${parent}"/>
            <child link="wheel${wheel}_roller1${suffix}_link"/>
            <axis xyz="0 0 1"/>
            <dynamics friction="0.1"/> <!--摩擦系数-->
            <mimic joint="wheel${wheel}_joint" multiplier="1.0" offset="0.0"/>
        </joint>

        <link name="wheel${wheel}_roller1${suffix}_link">
            <visual>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <geometry>
                    <mesh filename="package://daxbot_description/meshes/x7_pro/roller1_Link.STL"/>
                </geometry>
                <material
                    name="">
                  <color
                    rgba="0.38431 0.38431 0.38431 1" />
                </material>
            </visual>

            <collision>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <geometry>
                    <mesh filename="package://daxbot_description/meshes/x7_pro/roller1_Link.STL"/>
                </geometry>
            </collision>

            <inertial>
                <origin xyz="-5.5511E-17 1.6417E-13 0.0093397" rpy="0.0 0.0 0.0"/>
                <mass value="0.020583"/>
                <inertia ixx="2.6317E-06"
                         ixy="-4.776E-22"
                         ixz="4.2777E-22"
                         iyy="2.6317E-06"
                         iyz="5.9334E-17"
                         izz="3.7888E-06"/>
            </inertial>
        </link>
    </xacro:macro>

    <xacro:macro name="insert_roller2" params="parent theta suffix wheel"> <!--小从动轮-->
        <joint name="wheel${wheel}_roller2${suffix}_joint" type="continuous">
            <origin xyz="0.0 ${-distance_to_roller2_center*cos(1.911+theta)} ${-distance_to_roller2_center*sin(1.911+theta)}" rpy="${theta-1.2623} 0.0 0.0"/>
            <parent link="${parent}"/>
            <child link="wheel${wheel}_roller2${suffix}_link"/>
            <axis xyz="0 0 1"/> 
            <dynamics friction="0.1"/> <!--摩擦系数-->
            <mimic joint="wheel${wheel}_joint" multiplier="1.0" offset="0.0"/>
        </joint>

        <link name="wheel${wheel}_roller2${suffix}_link">
            <visual>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <geometry>
                    <mesh filename="package://daxbot_description/meshes/x7_pro/roller2_Link.STL"/>
                </geometry>
                <material
                    name="">
                  <color
                    rgba="0.29804 0.29804 0.29804 1" />
                </material>
            </visual>

            <collision>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <geometry>
                    <mesh filename="package://daxbot_description/meshes/x7_pro/roller2_Link.STL"/>
                </geometry>
            </collision>

            <inertial>
                <origin xyz="0 1.588E-12 0.0075" rpy="0.0 0.0 0.0"/>
                <mass value="0.0050941"/>
                <inertia ixx="3.0922E-07"
                         ixy="4.0106E-23"
                         ixz="3.8886E-23"
                         iyy="3.0922E-07"
                         iyz="-4.5919E-17"
                         izz="3.8637E-07"/>
            </inertial>
        </link>
    </xacro:macro>

    <xacro:macro name="wheel" params="parent suffix theta">
        <joint name="wheel${suffix}_joint" type="continuous">
            <origin xyz="${chassis_radius*cos(theta)} ${chassis_radius*sin(theta)} 0.019929" rpy="0.0 0.0 ${theta-PI}"/>
            <parent link="${parent}"/>
            <child link="wheel${suffix}_link"/>
            <axis xyz="1 0 0"/>
        </joint>

        <link name="wheel${suffix}_link">
            <visual>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <geometry>
                    <mesh filename="package://daxbot_description/meshes/x7_pro/wheel_Link0.STL"/>
                </geometry>
                <material
                  name="">
                  <color
                    rgba="0.86667 0.86667 0.8902 1" />
                </material>
            </visual>

            <collision>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <geometry>
                    <mesh filename="package://daxbot_description/meshes/x7_pro/wheel_Link0.STL"/>
                </geometry>
            </collision>

            <inertial>
                <origin xyz="-0.00035264 5.7362E-06 0.00010664" rpy="0.0 0.0 0.0"/>
                <mass value="0.7255"/>
                <inertia 
                  ixx="0.0047119"
                  ixy="-2.2223E-07"
                  ixz="-4.2527E-06"
                  iyy="0.0026712"
                  iyz="-6.4395E-08"
                  izz="0.0026717"/>
            </inertial>
        </link>

        <xacro:insert_roller1 parent="wheel${suffix}_link"  theta="${0*2*PI/13}" suffix="1" wheel="${suffix}"/>
        <xacro:insert_roller1 parent="wheel${suffix}_link"  theta="${1*2*PI/13}" suffix="2" wheel="${suffix}"/>
        <xacro:insert_roller1 parent="wheel${suffix}_link"  theta="${2*2*PI/13}" suffix="3" wheel="${suffix}"/>
        <xacro:insert_roller1 parent="wheel${suffix}_link"  theta="${3*2*PI/13}" suffix="4" wheel="${suffix}"/>
        <xacro:insert_roller1 parent="wheel${suffix}_link"  theta="${4*2*PI/13}" suffix="5" wheel="${suffix}"/>
        <xacro:insert_roller1 parent="wheel${suffix}_link"  theta="${5*2*PI/13}" suffix="6" wheel="${suffix}"/>
        <xacro:insert_roller1 parent="wheel${suffix}_link"  theta="${6*2*PI/13}" suffix="7" wheel="${suffix}"/>
        <xacro:insert_roller1 parent="wheel${suffix}_link"  theta="${7*2*PI/13}" suffix="8" wheel="${suffix}"/>
        <xacro:insert_roller1 parent="wheel${suffix}_link"  theta="${8*2*PI/13}" suffix="9" wheel="${suffix}"/>
        <xacro:insert_roller1 parent="wheel${suffix}_link"  theta="${9*2*PI/13}" suffix="10" wheel="${suffix}"/>
        <xacro:insert_roller1 parent="wheel${suffix}_link"  theta="${10*2*PI/13}" suffix="11" wheel="${suffix}"/>
        <xacro:insert_roller1 parent="wheel${suffix}_link"  theta="${11*2*PI/13}" suffix="12" wheel="${suffix}"/>
        <xacro:insert_roller1 parent="wheel${suffix}_link"  theta="${12*2*PI/13}" suffix="13" wheel="${suffix}"/>

        <xacro:insert_roller2 parent="wheel${suffix}_link"  theta="${0*2*PI/13}"  suffix="1" wheel="${suffix}"/>
        <xacro:insert_roller2 parent="wheel${suffix}_link"  theta="${1*2*PI/13}"  suffix="2" wheel="${suffix}"/>
        <xacro:insert_roller2 parent="wheel${suffix}_link"  theta="${2*2*PI/13}" suffix="3" wheel="${suffix}"/>
        <xacro:insert_roller2 parent="wheel${suffix}_link"  theta="${3*2*PI/13}" suffix="4" wheel="${suffix}"/>
        <xacro:insert_roller2 parent="wheel${suffix}_link"  theta="${4*2*PI/13}" suffix="5" wheel="${suffix}"/>
        <xacro:insert_roller2 parent="wheel${suffix}_link"  theta="${5*2*PI/13}" suffix="6" wheel="${suffix}"/>
        <xacro:insert_roller2 parent="wheel${suffix}_link"  theta="${6*2*PI/13}" suffix="7" wheel="${suffix}"/>
        <xacro:insert_roller2 parent="wheel${suffix}_link"  theta="${7*2*PI/13}" suffix="8" wheel="${suffix}"/>
        <xacro:insert_roller2 parent="wheel${suffix}_link"  theta="${8*2*PI/13}" suffix="9" wheel="${suffix}"/>
        <xacro:insert_roller2 parent="wheel${suffix}_link"  theta="${9*2*PI/13}" suffix="10" wheel="${suffix}"/>
        <xacro:insert_roller2 parent="wheel${suffix}_link"  theta="${10*2*PI/13}" suffix="11" wheel="${suffix}"/>
        <xacro:insert_roller2 parent="wheel${suffix}_link"  theta="${11*2*PI/13}" suffix="12" wheel="${suffix}"/>
        <xacro:insert_roller2 parent="wheel${suffix}_link"  theta="${12*2*PI/13}" suffix="13" wheel="${suffix}"/>
    </xacro:macro>
</robot>
