<robot
  name="dax_robot">

  <link name="odom"/>

  <!-- 中间链接，用于X方向移动 -->
  <link name="base_footprint_x">
  </link>

  <!-- X方向平移关节 -->
  <joint name="planar_joint_x" type="prismatic">
    <parent link="odom"/>
    <child link="base_footprint_x"/>
    <axis xyz="1 0 0"/>
    <limit lower="-10" upper="10" effort="100" velocity="1.0"/>
  </joint>

  <!-- 中间链接，用于Y方向移动 -->
  <link name="base_footprint_y">
  </link>

  <!-- Y方向平移关节 -->
  <joint name="planar_joint_y" type="prismatic">
    <parent link="base_footprint_x"/>
    <child link="base_footprint_y"/>
    <axis xyz="0 1 0"/>
    <limit lower="-10" upper="10" effort="100" velocity="1.0"/>
  </joint>

  <link name="base_footprint">
  </link>

  <!-- 旋转关节 -->
  <joint name="planar_joint_theta" type="continuous">
    <parent link="base_footprint_y"/>
    <child link="base_footprint"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" velocity="1.0"/>
  </joint>
  
  <joint name="base_footprint_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_footprint"/>
    <child link="base_link" />
  </joint>

